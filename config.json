{
    "title": "凉城的博客",
    "subTitle": "岂能尽如人意 但求无愧我心",
    "avatarUrl": "https://pic.20071008.xyz/img/%E5%BE%AE%E4%BF%A1%E5%9B%BE%E7%89%87_2025-08-11_100352_869.jpg",
    "GMEEK_VERSION": "last",
    "startSite": "09/09/2025",
    
    // 添加以下配置项
    "script": `
<script>
document.addEventListener('DOMContentLoaded', function() {
    const hitokotoUrl = 'https://v1.hitokoto.cn/?c=i';
    const footerElement = document.querySelector('.footer-inner'); // 可能需要调整选择器
    
    if (footerElement) {
        fetch(hitokotoUrl)
            .then(response => response.json())
            .then(data => {
                const hitokotoText = data.hitokoto + ' —— ' + data.from;
                const originalHtml = footerElement.innerHTML;
                footerElement.innerHTML = '<div style="margin-bottom: 8px;">' + hitokotoText + '</div>' + originalHtml;
            })
            .catch(error => {
                console.error('获取一言失败:', error);
            });
    }
});
</script>
`
}
